<UserControl x:Class="AICode.Vsix.AICodeToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Content="选中的代码:" Grid.Row="0" FontWeight="Bold"/>
        <TextBox x:Name="SelectedCodeTextBox" Grid.Row="1" Margin="0 5" IsReadOnly="True" 
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>

        <Label Content="输入指令:" Grid.Row="2" FontWeight="Bold" Margin="0 10 0 0"/>
        <TextBox x:Name="PromptTextBox" Grid.Row="3" Margin="0 5" TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0 10 0 0" HorizontalAlignment="Left">
            <Button x:Name="GenerateButton" Content="生成代码" Click="GenerateButton_Click" 
                    Width="80" Height="25" Margin="0 0 5 0"/>
            <Button x:Name="RefactorButton" Content="重构代码" Click="RefactorButton_Click" 
                    Width="80" Height="25" Margin="0 0 5 0"/>
            <Button x:Name="ExplainButton" Content="解释代码" Click="ExplainButton_Click" 
                    Width="80" Height="25" Margin="0 0 5 0"/>
            <Button x:Name="FindIssuesButton" Content="查找问题" Click="FindIssuesButton_Click" 
                    Width="80" Height="25" Margin="0 0 5 0"/>
            <Button x:Name="InsertButton" Content="插入到编辑器" Click="InsertButton_Click" 
                    Width="100" Height="25"/>
        </StackPanel>

        <Label Content="结果:" Grid.Row="5" FontWeight="Bold" Margin="0 10 0 0"/>
        <TextBox x:Name="ResultTextBox" Grid.Row="6" Margin="0 5" IsReadOnly="True" 
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
    </Grid>
</UserControl>
