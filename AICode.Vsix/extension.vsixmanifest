<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011">
  <Metadata>
    <Identity Id="AICode.Vsix.9A5B3C7D-1E2F-4A6B-8C9D-0E1F2A3B4C5D" Version="1.0.0" Language="en-US" Publisher="AICode" />
    <DisplayName>AICode Assistant</DisplayName>
    <Description xml:space="preserve">Visual Studio 2026 AI代码助手，支持GPT、Claude等顶尖大模型，提供代码补全、生成、重构和审查功能。</Description>
    <Tags>AI, Code, C++, C#, Copilot, GPT-4, Claude</Tags>
  </Metadata>
  <Installation ExtensionType="VSSDK">
    <InstallationTarget Id="Microsoft.VisualStudio.Community" Version="[18.0,19.0)" ProductArchitecture="amd64" />
    <InstallationTarget Id="Microsoft.VisualStudio.Pro" Version="[18.0,19.0)" ProductArchitecture="amd64" />
    <InstallationTarget Id="Microsoft.VisualStudio.Enterprise" Version="[18.0,19.0)" ProductArchitecture="amd64" />
  </Installation>
  <Dependencies>
    <Dependency Id="Microsoft.Framework.NDP" DisplayName="Microsoft .NET Framework" Version="[4.8,)" />
  </Dependencies>
  <Assets>
    <Asset Type="Microsoft.VisualStudio.VsPackage" Path="AICode.Vsix.pkgdef" />
    <Asset Type="Microsoft.VisualStudio.MefComponent" Path="AICode.Vsix.dll" />
    <Asset Type="Microsoft.VisualStudio.Assembly" Path="AICode.Core.dll" />
    <Asset Type="Microsoft.VisualStudio.Assembly" Path="libcurl.dll" />
  </Assets>
  <Prerequisites>
    <Prerequisite Id="Microsoft.VisualStudio.Component.CoreEditor" Version="[18.0,19.0)" DisplayName="Visual Studio core editor" />
    <Prerequisite Id="Microsoft.VisualStudio.Component.NuGet" Version="[18.0,19.0)" DisplayName="NuGet package manager" />
  </Prerequisites>
</PackageManifest>
